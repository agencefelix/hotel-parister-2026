{% trans_default_domain 'front_default' %}

{% if not form.isRendered() %}
    <div class="content newsletter-content">
        <div class="newsletter-heading text-center">
            <span class="newsletter-kicker d-block text-uppercase">{{ "Rejoignez notre"|trans }}</span>
            <span class="newsletter-title d-block" aria-hidden="true">{{ "newsletter"|trans }}</span>
            <h2 class="visually-hidden">{{ "Rejoignez notre newsletter"|trans }}</h2>
        </div>
        {{ form_start(form, {attr: {
            id: "newsletter-form-"~campaign.id,
            class: campaign.recaptcha ? 'security newsletter-form' : 'newsletter-form',
            action: path('front_newsletter_view', {filter: campaign.slug, website: website.id}),
            novalidate: "novalidate",
            'data-modal': modalId
        }}) }}
            {% include 'front/'~websiteTemplate~'/include/recaptcha-fields.html.twig' with {entity: campaign} %}
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-12 col-lg-10 col-xl-8">
                        <label class="visually-hidden" for="front_newsletter_email">{{ "Votre e-mail"|trans }}</label>
                        <div id="newsletter-fields" class="newsletter-fields-wrap d-flex align-items-center">
                            <div class="newsletter-email flex-grow-1">{{ form_widget(form.email) }}</div>
                            <span class="newsletter-sep" aria-hidden="true"></span>
                            <button aria-label="{{ "Envoyer"|trans|raw }}" class="newsletter-submit newsletter-track text-uppercase fw-600">
                                <span class="newsletter-submit-label">{{ "Envoyer"|trans }}</span>
                                <span class="spinner-border d-none" role="status"></span>
                            </button>
                        </div>
                        {{ form_errors(form.email) }}
                        {% for type, flashes in app.session.flashbag.all %}
                            {% for flash in flashes %}
                                <span class="{% if 'error' in type %}invalid{% else %}valid{% endif %}-feedback d-block">
                                    <span class="mb-0 d-block">
                                        <span class="form-{% if 'error' in type %}error{% else %}success{% endif %}-message">{{ flash|raw }}</span>
                                    </span>
                                </span>
                            {% endfor %}
                        {% endfor %}
                        <div class="newsletter-consent form-check d-flex align-items-start mt-4">
                            {{ form_widget(form.consent, {attr: {class: 'newsletter-consent-check form-check-input flex-shrink-0'}}) }}
                            {{ form_label(form.consent, null, {label_attr: {class: 'newsletter-consent-text form-check-label'}}) }}
                            {{ form_errors(form.consent) }}
                        </div>
                        {% if intro|striptags|length > 0 %}
                            <p class="newsletter-intro mt-3 mb-0">{{ intro|unescape|raw|nl2br }}</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        {{ form_end(form) }}
    </div>
{% endif %}
