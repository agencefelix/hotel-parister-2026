{% trans_default_domain 'front_default' %}

{% import 'core/webmaster-edit.html.twig' as macroWebmaster %}

{% set logo = logos.logo is defined and logos.logo ? logos.logo : null %}
{% set companyName = informationIntl.title is defined and informationIntl.title ? informationIntl.title : "Parister"|trans|raw %}
{% set links = tree.main is defined ? tree.main : [] %}
{% set compagnyNameElement = (seo.titleH1 is defined and not seo.titleH1 or seo.titleH1 is not defined) ? 'h1' : 'strong' %}
{% if seo.card is defined and seo.card %}
    {% set compagnyNameElement = 'strong' %}
{% endif %}
{% set bookingUrl = path('front_index', {url: 'chambres-suites'}) %}
{% set giftUrl = path('front_index', {url: 'bons-cadeaux'}) %}
{% set wellnessUrl = path('front_index', {url: 'sport-bien-etre'}) %}
{% set zonePhones = website.infoZones.phones.footer is defined ? website.infoZones.phones.footer : [] %}
{% set zoneEmails = website.infoZones.emails.footer is defined ? website.infoZones.emails.footer : [] %}

<div id="menu-container-{{ slug }}" class="menu-container w-100 as-sticky always-sticky {{ dropdownClass }}"
     data-expand="{{ expand }}"
     tabindex="0">
    {{ macroWebmaster.box({
        title: "Éditer le menu"|trans([], 'front_webmaster'),
        role: 'ROLE_NAVIGATION',
        path: path('admin_menu_edit', {website: website.id, menu: id, entitylocale: app.request.locale})
    }) }}

    {# ===================== BARRE FERMÉE ===================== #}
    <header id="main-navigation" class="navbar py-3 py-lg-4">
        <div class="container-fluid px-3 px-lg-5 d-flex align-items-center">
            {# Gauche : ouvre le mega-menu #}
            <div class="flex-fill d-flex justify-content-start">
                <button class="navbar-toggler nav-burger bg-transparent border-0 p-0 d-inline-flex align-items-center"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#main-navigation-nav"
                        aria-controls="main-navigation-nav"
                        aria-expanded="false"
                        aria-label="{{ "Ouvrir le menu"|trans|striptags }}">
                    <span class="nav-toggler-icon" aria-hidden="true">
                        <span></span>
                        <span></span>
                        <span></span>
                    </span>
                    <span class="label text-uppercase ms-2 fw-600 d-inline-block">{{ "Menu"|trans|raw }}</span>
                </button>
            </div>

            {# Centre : logo #}
            {% if logo %}
                <{% if 'h1' == compagnyNameElement %}h1{% else %}strong{% endif %} class="d-none" aria-hidden="true">{{ companyName|striptags }}</{% if 'h1' == compagnyNameElement %}h1{% else %}strong{% endif %}>
                <a class="navbar-brand p-0 m-0" aria-label="{{ companyName|striptags }}" href="{{ app.request.getSchemeAndHttpHost() }}" data-toggle="preloader">
                    {{ asset(logo)|file({}, {
                        screensSizes: {
                            mobile: {width: 120, height: 52},
                            tablet: {width: 138, height: 60},
                            desktop: {width: 138, height: 60}
                        },
                        decor: false,
                        title: companyName,
                        class: 'force-size logo initial-color',
                        only_html: false,
                        lazyLoad: false,
                        priority: 'high'
                    }) }}
                </a>
            {% endif %}

            {# Droite : RÉSERVER · BONS CADEAUX (texte, conforme maquette) #}
            <div class="flex-fill d-flex align-items-center justify-content-end">
                <a href="{{ bookingUrl }}" class="nav-bar-link text-uppercase fw-600" data-toggle="preloader">{{ "Réserver"|trans|raw }}</a>
                <span class="nav-bar-sep mx-3" aria-hidden="true"></span>
                <a href="{{ giftUrl }}" class="nav-bar-link text-uppercase fw-600 d-none d-sm-inline-block" data-toggle="preloader">{{ "Bons cadeaux"|trans|raw }}</a>
            </div>
        </div>
    </header>

    {# ===================== MEGA-MENU OUVERT ===================== #}
    <div id="main-navigation-nav" class="collapse mega-menu">
        <div class="mega-menu-inner d-flex flex-column">

            {# --------- Barre haute (mode ouvert) --------- #}
            <div class="mega-topbar d-flex align-items-center px-3 px-lg-5 py-3">
                <div class="flex-fill d-flex justify-content-start">
                    <button class="nav-close bg-transparent border-0 p-0 d-inline-flex align-items-center text-uppercase fw-600"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#main-navigation-nav"
                            aria-label="{{ "Fermer le menu"|trans|striptags }}">
                        <span class="nav-close-icon me-2" aria-hidden="true">&#10005;</span>
                        <span class="d-none d-lg-inline">{{ "Menu"|trans|raw }}</span>
                        <span class="d-lg-none">{{ "Fermer"|trans|raw }}</span>
                    </button>
                </div>
                {% if logo %}
                    <a class="navbar-brand p-0 m-0" aria-label="{{ companyName|striptags }}" href="{{ app.request.getSchemeAndHttpHost() }}" data-toggle="preloader">
                        {{ asset(logo)|file({}, {
                            screensSizes: {mobile: {width: 110, height: 48}, tablet: {width: 130, height: 56}, desktop: {width: 130, height: 56}},
                            decor: false, title: companyName, class: 'force-size logo initial-color', only_html: false, lazyLoad: false, priority: 'high'
                        }) }}
                    </a>
                {% endif %}
                <div class="flex-fill d-flex align-items-center justify-content-end">
                    <a href="{{ bookingUrl }}" class="mega-topbar-link text-uppercase fw-600" data-toggle="preloader">{{ "Réserver"|trans|raw }}</a>
                    <span class="mega-topbar-sep mx-3 d-none d-lg-inline-block" aria-hidden="true"></span>
                    <a href="{{ giftUrl }}" class="mega-topbar-link text-uppercase fw-600 d-none d-lg-inline-block" data-toggle="preloader">{{ "Bons cadeaux"|trans|raw }}</a>
                </div>
            </div>

            {# --------- Corps : 2 panneaux --------- #}
            <div class="mega-body d-flex flex-column flex-lg-row flex-grow-1">

                {# --------- Panneau gauche : navigation --------- #}
                <div class="mega-panel mega-panel-nav d-flex flex-column">
                    {% if multiLingues %}
                        <div class="mega-lang-wrap mb-4">
                            {{ render_esi(path('front_locales_switcher', {class: 'mega-lang'|url_encode, classname: currentClassname|url_encode, entityId: currentEntityId} )) }}
                        </div>
                    {% endif %}

                    <nav class="row gx-4 gy-5 mega-cols" role="navigation" aria-label="{{ "Navigation principale"|trans|striptags }}">
                        {% for group in links %}
                            {% if group.online is not defined or group.online %}
                                <div class="col-6 mega-col">
                                    <span class="mega-col-title d-block text-uppercase fw-600 mb-3">{{ group.title|unescape|raw }}</span>
                                    {% if group.children %}
                                        <ul class="reset mega-col-list">
                                            {% for child in group.children %}
                                                {% if child.online is not defined or child.online %}
                                                    <li class="mb-2{% if child.active %} active{% endif %}">
                                                        <a class="mega-link{% if child.active %} active{% endif %}"
                                                           href="{{ child.link ? child.link : 'javascript:void(0)' }}"
                                                           {% if child.linkBlank %}target="_blank"{% else %}data-toggle="preloader"{% endif %}
                                                           {% if child.linkExternal %}rel="noopener noreferrer"{% endif %}>
                                                            {{ child.title|unescape|raw }}
                                                        </a>
                                                    </li>
                                                {% endif %}
                                            {% endfor %}
                                        </ul>
                                    {% endif %}
                                </div>
                            {% endif %}
                        {% endfor %}
                    </nav>
                </div>

                {# --------- Panneau droit : média + CTA + contact --------- #}
                <aside class="mega-panel mega-panel-aside p-0 d-flex flex-column">
                    <div class="mega-aside-media">
                        <img src="{{ asset('medias/facade-parister.jpg') }}" alt="{{ companyName|striptags }}" class="w-100 object-fit-cover" loading="lazy" width="640" height="450">
                    </div>

                    <div class="mega-aside-body d-flex flex-column flex-grow-1">
                        <ul class="reset mega-cta-list">
                            <li>
                                <a class="mega-cta d-flex align-items-center justify-content-between text-uppercase" href="{{ giftUrl }}" data-toggle="preloader">
                                    <span>{{ "Bons cadeaux"|trans|raw }}</span><i class="icon-arrow-right" aria-hidden="true"></i>
                                </a>
                            </li>
                            <li>
                                <a class="mega-cta d-flex align-items-center justify-content-between text-uppercase" href="{{ wellnessUrl }}" data-toggle="preloader">
                                    <span>{{ "Offres bien-être"|trans|raw }}</span><i class="icon-arrow-right" aria-hidden="true"></i>
                                </a>
                            </li>
                            <li>
                                <a class="mega-cta d-flex align-items-center justify-content-between text-uppercase" href="{{ bookingUrl }}" data-toggle="preloader">
                                    <span>{{ "Réservation"|trans|raw }}</span><i class="icon-arrow-right" aria-hidden="true"></i>
                                </a>
                            </li>
                        </ul>

                        {% if website.networks %}
                            <nav class="socials-list d-flex justify-content-center mt-4 mb-4" aria-label="{{ "Navigation des liens sociaux"|trans|striptags }}">
                                {% for name, infos in website.networks %}
                                    {% if infos.link and infos.dirname %}
                                        {% set label = name|striptags|capitalize~' - '~'nouvelle fenêtre'|trans|striptags %}
                                        <span role="button" class="{{ name }} p-0 d-inline-flex mx-2 js-open-window" data-url="{{ infos.link }}" aria-label="{{ label }}">
                                            <i class="icon-{{ name|lower }}" aria-hidden="true"></i>
                                            <span class="visually-hidden">{{ label }}</span>
                                        </span>
                                    {% endif %}
                                {% endfor %}
                            </nav>
                        {% endif %}

                        {% for address in website.addresses %}
                            {% set phones = address.phones is not empty ? address.phones : zonePhones %}
                            {% set emails = address.emails is not empty ? address.emails : zoneEmails %}
                            <address class="mega-contact text-center mt-auto mb-0">
                                <span class="d-block text-uppercase">{% if address.address %}{{ address.address|raw }}{% if address.zipCode or address.city %}, {% endif %}{% endif %}{% if address.zipCode %}{{ address.zipCode }} {% endif %}{% if address.city %}{{ address.city }}{% endif %}</span>
                                {% if phones is not empty %}
                                    <span class="d-block mt-2">{% for phone in phones %}{{ phone|phone(website, {icon: false, only_href: true}) }}{% endfor %}</span>
                                {% endif %}
                                {% if emails is not empty %}
                                    <span class="d-block text-uppercase">{% for email in emails %}{{ email.email|email(website, {icon: false, only_href: true}) }}{% endfor %}</span>
                                {% endif %}
                            </address>
                        {% endfor %}
                    </div>
                </aside>

                {# Forstyle : bas du panneau gauche en desktop (absolu), dernier bloc en mobile #}
                <div class="mega-forstyle text-center">
                    <span class="d-block text-uppercase mega-forstyle-label mb-2">{{ "Un hôtel by"|trans|raw }}</span>
                    <img src="{{ asset('medias/forstyle-logo.png') }}" alt="Forstyle Hotels Collection" class="mega-forstyle-logo" loading="lazy" width="150" height="100">
                </div>
            </div>
        </div>
    </div>
</div>
